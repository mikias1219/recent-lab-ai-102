# Copy this file to `.env` and fill in values.
# This repo ignores `.env` files so secrets won't be committed.
#
# Document Intelligence endpoint + key (and Forms Recognizer aliases for Lab 04):
#   After `az login`, run from repo root:
#   python scripts/sync_document_intelligence_env.py -g YOUR_RG -n YOUR_DOC_INTEL_RESOURCE_NAME
#   Or list names:  python scripts/sync_document_intelligence_env.py -g YOUR_RG --list-accounts

